# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงของคุณ:
#   cp .env.example .env
#
# หมายเหตุ: ไฟล์ .env ถูก gitignore ไว้แล้ว ห้าม commit คีย์จริงขึ้น repo

# OpenRouter API key — ขอได้ที่ https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endpoint ของ OpenRouter (ใช้รูปแบบ OpenAI-compatible)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# โมเดลที่ใช้ผ่าน OpenRouter (ทดสอบแล้วใช้งานได้)
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# URL ของ MCP MSSQL Server จริง (Streamable HTTP) ของหลักสูตรที่ 1
# เปิด MCP MSSQL ในเครื่องแล้ว expose ผ่าน ngrok แล้วนำ URL มาใส่ที่นี่
# (เปลี่ยนเป็น MCP Server อื่น เช่น RAG :8000 ได้โดยไม่ต้องแก้โค้ด Agent)
MCP_SERVER_URL=https://your-ngrok-subdomain.ngrok-free.app/mcp
